<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - AI Orchestrator</title>
    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                🤖 AI Orchestrator
            </div>
            <nav class="sidebar-nav">
                <a href="@Url.Action("Index", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    📊 Dashboard
                </a>
                <a href="@Url.Action("Tasks", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Tasks" ? "active" : "")">
                    ✓ Tasks
                </a>
                <a href="@Url.Action("AuditLog", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLog" ? "active" : "")">
                    📋 Audit Log
                </a>
                <a href="@Url.Action("Settings", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")">
                    ⚙️ Settings
                </a>
            </nav>
        </aside>

        <div class="main-content">
            <header class="topbar">
                <h1 class="topbar-title">@ViewData["Title"]</h1>
                <div class="topbar-actions">
                    <span style="font-size: 12px; color: #7f8c8d;">
                        @User.Identity?.Name ?? "Authenticated"
                    </span>
                </div>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
    (() => {
        const params = new URLSearchParams(window.location.search);
        const token = params.get('token');
        if (token) {
            localStorage.setItem('token', token);
        }
    })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/signalr.min.js"></script>
    <script src="~/js/dashboard.js"></script>
</body>
</html>
